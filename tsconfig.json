{
  // https://nuxt.com/docs/guide/concepts/typescript
  "extends": "./.nuxt/tsconfig.json",
  "compilerOptions": {
    "moduleResolution": "bundler",
    "baseUrl": ".",
    "paths": {
      "@/*": [
        "src/*"
      ],
      "@/tests/*": [
        "tests/*"
      ],
      "@/presentation/*": [
        "src/presentation/*",
        "src/presentation/*.vue"
      ]
    },
    "types": [
      "@types/node",
      "@nuxtjs/i18n",
      "vite/client"
    ],
    "resolveJsonModule": true,
    "esModuleInterop": true,
    "allowJs": true,
    "skipLibCheck": true,
    "noImplicitAny": false,
    "module": "ESNext"
  },
  "include": [
    "**/*.vue",
    "**/*.ts",
    "**/*.js"
  ]
}
